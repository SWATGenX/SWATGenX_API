# Copy to .env and fill in (never commit .env to git).
SWATGENX_API_KEY=sgx_your_key_from_subscription_settings
SWATGENX_BASE_URL=https://www.swatgenx.com

# After a run completes, paste the full URL from the completion email (secret — do not commit).
# SWATGENX_DOWNLOAD_URL=https://www.swatgenx.com/download_model/<token>
# SWATGENX_OUT_ZIP=./SWAT_Model.zip
